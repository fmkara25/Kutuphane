@model Kutuphane.Models.Book
@using Kutuphane.Models

@{
    ViewData["Title"] = "Add Book";
}

<section class="hero-card mb-4">
    <div class="hero-eyebrow mb-2">New book</div>

    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-end">
        <div>
            <h1 class="hero-title mb-3">Add a book</h1>
            <p class="hero-subtitle mb-0">
                Fill in the details below and save the book to your personal library.
            </p>
        </div>

        <a asp-controller="Books" asp-action="Index" class="btn btn-light">
            <i class="bi bi-arrow-left me-1"></i> Back to Library
        </a>
    </div>
</section>

<div class="row g-4 align-items-start">
    <div class="col-lg-7">
        <div class="form-panel">
            <form action="/Books/Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold"></label>
                    <input asp-for="Title" class="form-control form-control-lg" placeholder="Book title" />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Author" class="form-label fw-semibold"></label>
                    <input asp-for="Author" class="form-control" placeholder="Author name" />
                    <span asp-validation-for="Author" class="text-danger small"></span>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Genre" class="form-label fw-semibold"></label>
                        <input asp-for="Genre" class="form-control" placeholder="Novel, fantasy, history..." />
                        <span asp-validation-for="Genre" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Status" class="form-label fw-semibold"></label>
                        <select asp-for="Status" class="form-select">
                            <option value="@ReadingStatus.Okuyorum">Reading</option>
                            <option value="@ReadingStatus.Okudum">Finished</option>
                            <option value="@ReadingStatus.Okuyacağım">Want to Read</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3 mt-3">
                    <label asp-for="CoverImageUrl" class="form-label fw-semibold"></label>
                    <input asp-for="CoverImageUrl" id="coverInput" class="form-control" placeholder="https://example.com/cover.jpg" />
                    <span asp-validation-for="CoverImageUrl" class="text-danger small"></span>
                </div>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="Rating" class="form-label fw-semibold"></label>
                        <input asp-for="Rating" class="form-control" type="number" step="0.1" min="0" max="5" placeholder="0-5" />
                        <span asp-validation-for="Rating" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="PageCount" class="form-label fw-semibold"></label>
                        <input asp-for="PageCount" class="form-control" type="number" min="1" placeholder="300" />
                        <span asp-validation-for="PageCount" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Progress" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <input asp-for="Progress" class="form-control" type="number" min="0" max="100" value="0" />
                            <span class="input-group-text">%</span>
                        </div>
                        <span asp-validation-for="Progress" class="text-danger small"></span>
                    </div>
                </div>

                <div class="form-check form-switch my-4">
                    <input asp-for="IsFavorite" class="form-check-input" />
                    <label asp-for="IsFavorite" class="form-check-label fw-semibold"></label>
                </div>

                <div class="mb-4">
                    <label asp-for="Notes" class="form-label fw-semibold"></label>
                    <textarea asp-for="Notes" class="form-control" rows="4" placeholder="Personal notes..."></textarea>
                    <span asp-validation-for="Notes" class="text-danger small"></span>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check2-circle me-1"></i> Save Book
                    </button>

                    <a asp-controller="Books" asp-action="Index" class="btn btn-outline-primary">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="cover-preview-card glass-card">
            <div class="p-4">
                <h2 class="h5 mb-1">Cover Preview</h2>
                <p class="text-muted mb-0 small">Paste a valid image URL to preview the cover.</p>
            </div>

            <div class="cover-preview-box p-4">
                <img id="coverPreview" src="" alt="Cover preview" class="img-fluid" style="display:none;" />

                <div id="coverPlaceholder" class="text-muted text-center">
                    <i class="bi bi-image display-5 d-block mb-2"></i>
                    No cover selected
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const input = document.getElementById('coverInput');
        const img = document.getElementById('coverPreview');
        const placeholder = document.getElementById('coverPlaceholder');

        input.addEventListener('input', function () {
            const value = input.value.trim();

            if (!value.startsWith('http')) {
                img.style.display = 'none';
                placeholder.style.display = 'block';
                return;
            }

            img.src = value;
            img.style.display = 'block';
            placeholder.style.display = 'none';
        });
    </script>
}