@model Kutuphane.Models.Book

@{
    ViewData["Title"] = "Delete Book";
}

<section class="hero-card mb-4">
    <div class="hero-eyebrow mb-2">Delete confirmation</div>

    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-end">
        <div>
            <h1 class="hero-title mb-3">Delete this book?</h1>
            <p class="hero-subtitle mb-0">
                This action cannot be undone. Please confirm before removing this book.
            </p>
        </div>

        <a href="/Books" class="btn btn-light">
            <i class="bi bi-arrow-left me-1"></i> Back to Library
        </a>
    </div>
</section>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="details-panel">
            <div class="d-flex flex-column flex-md-row gap-4 align-items-md-center">
                <div style="width: 160px; min-width: 160px;">
                    <div class="book-cover rounded-4 overflow-hidden" style="height: 220px;">
                        @if (!string.IsNullOrWhiteSpace(Model.CoverImageUrl))
                        {
                            <img src="@Model.CoverImageUrl" alt="@Model.Title cover" />
                        }
                        else
                        {
                            <div class="cover-placeholder">
                                <i class="bi bi-journal-bookmark display-5"></i>
                            </div>
                        }
                    </div>
                </div>

                <div class="flex-grow-1">
                    <h2 class="h3 mb-2">@Model.Title</h2>
                    <p class="text-muted mb-3">by @Model.Author</p>

                    <div class="alert alert-danger mb-4">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        You are about to permanently delete this book record.
                    </div>

                    <form action="/Books/Delete/@Model.Id" method="post" class="d-flex flex-wrap gap-2">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="Id" />

                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-trash me-1"></i> Yes, Delete
                        </button>

                        <a href="/Books/Details/@Model.Id" class="btn btn-outline-primary">
                            Cancel
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>