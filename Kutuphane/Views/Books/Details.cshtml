@model Kutuphane.Models.Book
@using Kutuphane.Models

@{
    ViewData["Title"] = "Book Details";

    string StatusText(ReadingStatus status) =>
        status == ReadingStatus.Okuyorum ? "Reading"
        : status == ReadingStatus.Okudum ? "Finished"
        : "Want to Read";

    var progress = Model.Progress ?? 0;
    var stars = Model.Rating.HasValue ? (int)Math.Round(Model.Rating.Value) : 0;
}

<section class="hero-card mb-4">
    <div class="hero-eyebrow mb-2">Book details</div>

    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 align-items-lg-end">
        <div>
            <h1 class="hero-title mb-3">@Model.Title</h1>
            <p class="hero-subtitle mb-0">Written by @Model.Author</p>
        </div>

        <a href="/Books" class="btn btn-light">
            <i class="bi bi-arrow-left me-1"></i> Back to Library
        </a>
    </div>
</section>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="details-panel">
            <div class="book-cover rounded-4 overflow-hidden mb-4">
                @if (!string.IsNullOrWhiteSpace(Model.CoverImageUrl))
                {
                    <img src="@Model.CoverImageUrl" alt="@Model.Title cover" />
                }
                else
                {
                    <div class="cover-placeholder">
                        <i class="bi bi-journal-bookmark display-4"></i>
                    </div>
                }
            </div>

            <div class="d-grid gap-2">
                <a href="/Books/Edit/@Model.Id" class="btn btn-primary">
                    <i class="bi bi-pencil-square me-1"></i> Edit Book
                </a>

                <a href="/Books/Delete/@Model.Id" class="btn btn-outline-danger">
                    <i class="bi bi-trash me-1"></i> Delete Book
                </a>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="details-panel">
            <div class="d-flex flex-wrap gap-2 mb-4">
                <span class="badge badge-soft fs-6">
                    <i class="bi bi-book me-1"></i>
                    @StatusText(Model.Status)
                </span>

                @if (!string.IsNullOrWhiteSpace(Model.Genre))
                {
                    <span class="badge badge-soft fs-6">
                        <i class="bi bi-tag me-1"></i>
                        @Model.Genre
                    </span>
                }

                @if (Model.IsFavorite)
                {
                    <span class="badge text-bg-warning fs-6">
                        <i class="bi bi-star-fill me-1"></i>
                        Favorite
                    </span>
                }
            </div>

            <div class="row g-3 mb-4">
                <div class="col-md-4">
                    <div class="glass-card stat-card h-100">
                        <div class="stat-label">Rating</div>

                        @if (Model.Rating.HasValue)
                        {
                            <div class="rating-stars mt-2">
                                @for (var i = 1; i <= 5; i++)
                                {
                                    <i class="bi @(i <= stars ? "bi-star-fill" : "bi-star")"></i>
                                }
                            </div>

                            <div class="fw-bold mt-1">@Model.Rating / 5</div>
                        }
                        else
                        {
                            <div class="text-muted mt-2">No rating</div>
                        }
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="glass-card stat-card h-100">
                        <div class="stat-label">Pages</div>
                        <div class="stat-value">
                            @(Model.PageCount.HasValue? Model.PageCount.Value : 0)
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="glass-card stat-card h-100">
                        <div class="stat-label">Progress</div>
                        <div class="stat-value">@progress%</div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between small text-muted mb-2">
                <span>Reading Progress</span>
                <span>@progress%</span>
            </div>

            <div class="progress mb-4" style="height: 12px;">
                <div class="progress-bar" style="width:@progress%;"></div>
            </div>

            <h2 class="h5 mb-3">Notes</h2>

            @if (!string.IsNullOrWhiteSpace(Model.Notes))
            {
                <p class="mb-0">@Model.Notes</p>
            }
            else
            {
                <p class="text-muted mb-0">No notes added yet.</p>
            }
        </div>
    </div>
</div>