@{
    var title = ViewData["Title"] as string ?? "Kutuphane";
}

<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - Kutuphane</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>

<body>
    <div class="app-shell">
        <header class="topbar">
            <nav class="navbar navbar-expand-lg">
                <div class="container">
                    <a class="navbar-brand brand" href="/Books">
                        <span class="brand-icon">
                            <i class="bi bi-journal-bookmark-fill"></i>
                        </span>
                        <span>Kutuphane</span>
                    </a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="mainNav">
                        <ul class="navbar-nav ms-lg-4 me-auto gap-lg-2">
                            <li class="nav-item">
                                <a class="nav-link" href="/Books/Create">
                                    <i class="bi bi-plus-circle me-1"></i> Add Book
                                </a>
                            </li>
                        </ul>

                        <div class="d-flex gap-2">
                            <button id="themeToggle" class="btn btn-icon" type="button">
                                <i class="bi bi-moon-stars" id="themeIcon"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </nav>
        </header>

        <main class="container main-content">
            @RenderBody()
        </main>

        <footer class="footer">
            <div class="container d-flex flex-column flex-md-row justify-content-between gap-2">
                <span>© @DateTime.Now.Year Kutuphane</span>
                <span>ASP.NET Core MVC • EF Core • SQL Server</span>
            </div>
        </footer>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        const key = 'kutuphane-theme';
        const doc = document.documentElement;
        const icon = document.getElementById('themeIcon');
        const btn = document.getElementById('themeToggle');

        function apply(theme) {
            doc.setAttribute('data-bs-theme', theme);
            localStorage.setItem(key, theme);
            icon.className = theme === 'dark' ? 'bi bi-sun' : 'bi bi-moon-stars';
        }

        apply(localStorage.getItem(key) || 'light');

        btn.addEventListener('click', function () {
            const current = doc.getAttribute('data-bs-theme') || 'light';
            apply(current === 'dark' ? 'light' : 'dark');
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>